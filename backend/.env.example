# Puerto del API
PORT=3000

# Conexión a MongoDB
MONGODB_URI=mongodb://localhost:27017/autolavado

# Conexión a Redis (sesiones)
REDIS_URL=redis://localhost:6379

# Secreto para firmar JWT — generar uno propio:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SECRET_KEY=cambiame

# Orígenes permitidos para CORS, separados por coma
ALLOWED_ORIGINS=http://localhost:5173

# Admin inicial (se crea solo si no existe ningún admin)
ADMIN_EMAIL=admin@monkey.com
ADMIN_PASSWORD=admin

# Opcionales: credenciales del seed de usuarios demo (pnpm db:seed:users)
# SEED_CLIENT_EMAIL=cliente@monkey.com
# SEED_CLIENT_PASSWORD=cliente123
# SEED_WASHER_EMAIL=lavador@monkey.com
# SEED_WASHER_PASSWORD=lavador123
